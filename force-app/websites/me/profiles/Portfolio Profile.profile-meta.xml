<?xml version="1.0" encoding="UTF-8" ?>
<Profile xmlns="http://soap.sforce.com/2006/04/metadata">
    <classAccesses>
        <apexClass>ContactController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>PortfolioController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <!-- Guests need explicit CMDT access to SOQL-query the config record;
         getInstance() doesn't require it but truncates long text to 255. -->
    <customMetadataTypeAccesses>
        <enabled>true</enabled>
        <name>Portfolio_Config__mdt</name>
    </customMetadataTypeAccesses>
    <!-- Read is required by the platform to grant Create. Guests still can't
         see any Contact_Message__c records: no sharing rule grants them record
         access, so nothing is exposed. -->
    <objectPermissions>
        <object>Contact_Message__c</object>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>Experience__c</object>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>Project__c</object>
